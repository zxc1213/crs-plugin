  },
  "skills": [
    "req-manager",
    "req-brainstorm",
    "req-priority",
    "req-quality",
    "req-unify",
    "req-test-plan",
    "req-verify",
    "req-metrics",
    "req-init",
    "req-update",
    "req-change",
    "req-migrate"
  ],
  "commands": [
    "req",
    "req-init",
    "req-update",
    "req-priority",
    "req-quality",
    "req-test-plan",
    "req-verify",
    "req-brainstorm",
    "req-change",
    "req-migrate",
    "req-unify",
    "metrics"
  ],
  "hooks": {
    "PostToolUse": ["post-req-update"],
