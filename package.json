{
  "name": "crs-plugin",
  "version": "0.12.0",
  "description": "CRS Plugin - 智能需求管理系统，从需求到测试的全流程自动化",
  "type": "module",
  "files": [
    ".claude-plugin/",
    "skills/",
    "commands/",
    "hooks/",
    "scripts/",
    "bin/",
    "README.md"
  ],
  "keywords": [
    "claude-code",
    "plugin",
    "requirement-management",
    "automation",
    "skills"
  ],
  "author": "19944",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zxc1213/crs-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/zxc1213/crs-plugin/issues"
  },
  "homepage": "https://github.com/zxc1213/crs-plugin#readme",
  "bin": {
    "crs-init": "bin/crs-init.js",
    "crs-update": "bin/crs-update.js",
    "crs-track": "bin/crs-track.js",
    "crs-sync-plans": "bin/crs-sync-plans.js",
    "crs-skill-health": "bin/crs-skill-health.js",
    "crs-project-init": "bin/crs-project-init.js",
    "crs-project-sync": "bin/crs-project-sync.js",
    "crs-export": "bin/crs-export.js",
    "kg-search": "bin/kg-cli.js",
    "kg-stats": "bin/kg-cli.js",
    "kg-connections": "bin/kg-cli.js",
    "kg-recommend": "bin/kg-cli.js",
    "kg-rebuild": "bin/kg-cli.js"
  },
  "dependencies": {
    "cli-table3": "^0.6.5",
    "fs-extra": "^11.2.0",
    "fuse.js": "^7.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.0",
    "chai": "^5.1.2",
    "eslint": "^9.18.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "mocha": "^11.1.0",
    "prettier": "^3.4.2",
    "@eslint/js": "^9.18.0"
  },
  "scripts": {
    "sync-version": "node scripts/sync-version.js",
    "lint": "eslint scripts/",
    "lint:fix": "eslint scripts/ --fix",
    "format": "prettier --write \"scripts/**/*.js\"",
    "format:check": "prettier --check \"scripts/**/*.js\"",
    "test": "mocha \"tests/**/*.test.js\"",
    "test:coverage": "mocha \"tests/**/*.test.js\" --reporter json --reporter-option output=coverage.json",
    "test:verbose": "mocha \"tests/**/*.test.js\" --reporter spec",
    "test:watch": "mocha \"tests/**/*.test.js\" --watch",
    "prepack": "npm run sync-version",
    "version": "npm run sync-version && git add .",
    "prepublishOnly": "npm run sync-version"
  }
}
