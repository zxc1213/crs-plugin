{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"var p=require('path'),f=require('fs'),d=p.join(require('os').homedir(),'.claude'),s=[p.join(d,'plugins/marketplaces/crs/plugins/crs'),p.join(d,'plugins/cache/crs')],r='';for(var i of s){if(f.existsSync(i)){r=i;break}}if(!r)r=p.resolve('.');process.env.CLAUDE_PLUGIN_ROOT=r;require(p.join(r,'scripts/hooks/plugin-hook-bootstrap.cjs'))\" scripts/conversation-logger/hooks/session-start.js",
            "timeout": 5
          }
        ],
        "description": "初始化对话记录器",
        "id": "conv:session:start"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"var p=require('path'),f=require('fs'),d=p.join(require('os').homedir(),'.claude'),s=[p.join(d,'plugins/marketplaces/crs/plugins/crs'),p.join(d,'plugins/cache/crs')],r='';for(var i of s){if(f.existsSync(i)){r=i;break}}if(!r)r=p.resolve('.');process.env.CLAUDE_PLUGIN_ROOT=r;require(p.join(r,'scripts/hooks/plugin-hook-bootstrap.cjs'))\" scripts/hooks/post-req-update.js",
            "timeout": 10
          }
        ],
        "description": "更新需求记录",
        "id": "post:req:update"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"var p=require('path'),f=require('fs'),d=p.join(require('os').homedir(),'.claude'),s=[p.join(d,'plugins/marketplaces/crs/plugins/crs'),p.join(d,'plugins/cache/crs')],r='';for(var i of s){if(f.existsSync(i)){r=i;break}}if(!r)r=p.resolve('.');process.env.CLAUDE_PLUGIN_ROOT=r;require(p.join(r,'scripts/hooks/plugin-hook-bootstrap.cjs'))\" scripts/conversation-logger/hooks/post-tool-use.js",
            "timeout": 5
          }
        ],
        "description": "记录工具调用",
        "id": "conv:post:tool:use"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"var p=require('path'),f=require('fs'),d=p.join(require('os').homedir(),'.claude'),s=[p.join(d,'plugins/marketplaces/crs/plugins/crs'),p.join(d,'plugins/cache/crs')],r='';for(var i of s){if(f.existsSync(i)){r=i;break}}if(!r)r=p.resolve('.');process.env.CLAUDE_PLUGIN_ROOT=r;require(p.join(r,'scripts/hooks/plugin-hook-bootstrap.cjs'))\" scripts/hooks/stop-req-summary.js",
            "timeout": 10
          }
        ],
        "description": "生成需求执行总结",
        "id": "stop:req:summary"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"var p=require('path'),f=require('fs'),d=p.join(require('os').homedir(),'.claude'),s=[p.join(d,'plugins/marketplaces/crs/plugins/crs'),p.join(d,'plugins/cache/crs')],r='';for(var i of s){if(f.existsSync(i)){r=i;break}}if(!r)r=p.resolve('.');process.env.CLAUDE_PLUGIN_ROOT=r;require(p.join(r,'scripts/hooks/plugin-hook-bootstrap.cjs'))\" scripts/conversation-logger/hooks/stop.js",
            "timeout": 5
          }
        ],
        "description": "保存对话记录",
        "id": "conv:stop"
      }
    ]
  }
}
